# ============================================================================
# Configuration Supabase — copie ce fichier en `.env.local` et remplis les valeurs
# ============================================================================
#
# 1. Va sur https://app.supabase.com → New project (région : Frankfurt eu-central-1).
# 2. Dans Project Settings → API, récupère :
#    - "Project URL"      -> NEXT_PUBLIC_SUPABASE_URL
#    - "anon public key"  -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - "service_role key" -> SUPABASE_SERVICE_ROLE_KEY (à garder secret, jamais en client)
# 3. Lance les migrations (depuis la racine du projet) :
#    npx supabase login                         # une fois
#    npx supabase link --project-ref <ref>      # <ref> = ID du projet (Settings → General)
#    npx supabase db push                       # pousse 0001_schema.sql + 0002_status_options.sql
# 4. Dans Authentication → URL Configuration, ajoute :
#    Site URL                = http://localhost:3000
#    Redirect URLs           = http://localhost:3000/auth/callback
# 5. Crée ton compte : Authentication → Users → Add user (avec ton email).
# 6. npm run dev → ouvre http://localhost:3000, login par magic link.
#
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Côté serveur uniquement (script d'import CSV) — ne JAMAIS exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# Formulaires Tally — un par flow (création vs reprise)
NEXT_PUBLIC_TALLY_URL_CREATION=https://tally.so/r/XXXXXX
NEXT_PUBLIC_TALLY_URL_REPRISE=https://tally.so/r/YYYYYY
